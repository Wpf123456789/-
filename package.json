{
  "name": "patent-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "cd api && pnpm dev",
    "dev:all": "concurrently \"pnpm dev:api\" \"pnpm dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "clsx": "~2.1.1",
    "docx": "^9.6.1",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "react-router-dom": "~6.28.0",
    "tailwind-merge": "~2.5.4",
    "zod": "~3.23.8",
    "zustand": "~4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/node": "~22.8.1",
    "@types/react": "~18.3.12",
    "@types/react-dom": "~18.3.1",
    "@vitejs/plugin-react": "~3.1.0",
    "autoprefixer": "~10.4.20",
    "jsdom": "^23.0.1",
    "postcss": "~8.4.47",
    "tailwindcss": "~3.4.14",
    "typescript": "~5.6.3",
    "vite": "~5.4.10",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": "20.x"
  }
}
